---
import { href } from '../site';
import { deriveCategory, categoryName } from '../lib/taxonomy';

interface Surface { url: string; points: number | null; comments: number | null; name: string; }
/** The canonical pick contract — mirrors lib/schema.ts pickSchema.
 *  category/subcategories are optional: emitted by the pipeline when present,
 *  otherwise derived from the title + channels on the front end. */
export interface PickData {
  id: number; title: string; relevance: number; score: number;
  why: string; notes: string[]; summary: string; channels: string[];
  novelty: string | null; audience: string | null;
  source_url: string; read_kind: string | null; free_link: string | null;
  paywalled: boolean; surfaces: Surface[];
  sources_count: number; first_seen: string | null; curated_at: string;
  model: string | null;
  category?: string; subcategories?: string[];
}
interface Props { pick: PickData; index?: number; variant?: 'lead' | 'brief' | 'also'; }
const { pick, index = 0, variant = 'brief' } = Astro.props;
const delay = Math.min(index, 8) * 55;

const tax = pick.category
  ? { category: pick.category, subcategories: pick.subcategories ?? [] }
  : deriveCategory(pick.title, pick.channels);

// primary source first, always; backup free link when one exists
const primary = pick.source_url;
const free = pick.free_link && pick.free_link !== primary ? pick.free_link : null;
const date = (pick.curated_at || '').slice(0, 10);
const signalCount = pick.sources_count ?? pick.surfaces.length;

function hostOf(u: string): string {
  try { return new URL(u).hostname.replace(/^www\./, ''); } catch { return ''; }
}
const host = hostOf(primary);
const Heading = variant === 'lead' ? 'h2' : 'h3';
---
{variant === 'also' ? (
  <article class="also__item reveal" style={`animation-delay:${delay}ms`} data-pick-id={pick.id}>
    <span class="also__title"><a href={primary} target="_blank" rel="noopener">{pick.title}</a></span>
    {host && <span class="also__src">{host}</span>}
  </article>
) : (
  <article class={`pick pick--${variant} reveal`} style={`animation-delay:${delay}ms`} data-pick-id={pick.id}>
    <div class="pick__meta">
      <span class="pick__no" aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
      {host && <span class="pick__src">{host}</span>}
      {date && <span class="pick__date">{date}</span>}
      <a class="pick__tag" href={href(`/${tax.category}/`)}>{categoryName(tax.category)}</a>
      {tax.subcategories.slice(0, 2).map((s) => (
        <a class="pick__tag pick__tag--sub" href={href(`/${tax.category}/${s}/`)}>{s}</a>
      ))}
      <span class="pick__score">{pick.relevance}/10<span class="sep" aria-hidden="true"></span>score {Number(pick.score ?? 0).toFixed(1)}</span>
    </div>
    <Heading class="pick__title">
      <a href={primary} target="_blank" rel="noopener">{pick.title}</a>
    </Heading>
    {(pick.paywalled || free) && (
      <div class="pick__alt">
        {pick.paywalled && <span class="pick__tag pick__tag--pay">paywalled</span>}
        {free && <a class="pick__free" href={free} target="_blank" rel="noopener">free read →</a>}
      </div>
    )}
    {pick.why && <p class="pick__why">{pick.why}</p>}

    {variant === 'lead' ? (
      <>
        {pick.notes.length > 0 && (
          <ul class="pick__notes">
            {pick.notes.slice(0, 3).map((n) => <li>{n}</li>)}
          </ul>
        )}
        {pick.summary && (
          <details class="pick__details">
            <summary>Full summary</summary>
            <p class="pick__summary">{pick.summary}</p>
          </details>
        )}
      </>
    ) : (
      (pick.notes.length > 0 || pick.summary) && (
        <details class="pick__details">
          <summary>Details</summary>
          {pick.notes.length > 0 && (
            <ul class="pick__notes">
              {pick.notes.slice(0, 3).map((n) => <li>{n}</li>)}
            </ul>
          )}
          {pick.summary && <p class="pick__summary">{pick.summary}</p>}
        </details>
      )
    )}

    <aside class="pick__signals" aria-label="Curation signals">
      <span class="lab">Signals</span>
      <span>{signalCount} source{signalCount === 1 ? '' : 's'}</span>
      <span>relevance {pick.relevance}/10</span>
      <span>score {Number(pick.score ?? 0).toFixed(2)}</span>
      {pick.read_kind && pick.read_kind !== 'primary' && <span>read: {pick.read_kind}</span>}
      {pick.model && <span>curator: {pick.model}</span>}
      {date && <span>curated {date}</span>}
      {pick.surfaces.map((s) => (
        <a href={s.url} target="_blank" rel="noopener">
          {s.name}{s.points ? ` ${s.points} pts` : ''}{s.comments ? ` ${s.comments}c` : ''}
        </a>
      ))}
    </aside>
  </article>
)}
