---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Pick, { type PickData } from '../components/Pick.astro';
import Rail from '../components/Rail.astro';
import picksJson from '../data/picks.json';
import { site, href, KIND_LABEL, KINDS } from '../site';
import { CATEGORIES, deriveCategory } from '../lib/taxonomy';

const digests = (await getCollection('digests')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const latestDaily = digests.find((d) => d.data.kind === 'daily') ?? null;
// latest edition of each kind, for the rail's "Editions" index
const editions = KINDS.map((k) => digests.find((d) => d.data.kind === k)).filter(
  (d): d is (typeof digests)[number] => Boolean(d)
);
// the daily is surfaced as "the brief"; the rail's editions list is the longer view
const olderEditions = editions.filter((d) => d.id !== latestDaily?.id);

// The pipeline emits the v1 contract (channels[]); derive the public taxonomy
// here so the front page reads as a sectioned edition. When the pipeline emits
// category/subcategories natively, this passthrough simply uses them.
const picks = (picksJson as unknown as PickData[]).map((p) => {
  const tax = deriveCategory(p.title, p.channels);
  return { ...p, category: tax.category, subcategories: tax.subcategories } as PickData;
});

const lead = picks[0] ?? null;
const rest = lead ? picks.slice(1) : picks;

// Group the remainder by primary category; busiest sections lead the edition.
const PER_SECTION = 4;
const sections = CATEGORIES.map((cat) => ({
  cat,
  items: rest.filter((p) => p.category === cat.slug),
}))
  .filter((s) => s.items.length > 0)
  .sort((a, b) => b.items.length - a.items.length);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', timeZone: 'UTC' });
---
<Base wide={true}>
  <h1 class="sr-only">{site.name} — today's edition</h1>
  <div class="broadsheet">
    <div class="broadsheet__main">
      <p class="standfirst reveal">
        {site.name} watches where technology, AI, and the sciences break first,
        and keeps almost none of it. Stories that surface across many independent
        sources are read closely, scored, and explained — each pick links the
        primary source, with a free read when the original is walled.
        <a href={href('/about/')}>How it works →</a>
      </p>

      {lead && (
        <section class="reveal" aria-label="Lead story" data-category={lead.category}>
          <div class="rail">
            <span class="rail__label">Today's lead</span>
            <span class="rail__rule"></span>
          </div>
          <div class="briefing">
            <Pick pick={lead} index={0} variant="lead" />
          </div>
        </section>
      )}

      {sections.map((s) => (
        <section class="reveal" id={`s-${s.cat.slug}`} data-category={s.cat.slug} aria-label={s.cat.name}>
          <div class="rail">
            <span class="rail__label">{s.cat.name}</span>
            <span class="rail__rule"></span>
            <a class="rail__more" href={href(`/${s.cat.slug}/`)}>
              {s.items.length} {s.items.length === 1 ? 'story' : 'stories'} <span aria-hidden="true">→</span>
            </a>
          </div>
          <div class="briefing">
            {s.items.slice(0, PER_SECTION).map((p, i) => <Pick pick={p} index={i} variant="brief" />)}
          </div>
        </section>
      ))}
    </div>

    <Rail
      index={{
        title: 'In this edition',
        items: sections.map((s) => ({
          label: s.cat.name,
          href: `#s-${s.cat.slug}`,
          meta: s.items.length,
          category: s.cat.slug,
        })),
      }}
      brief={latestDaily ? {
        kind: KIND_LABEL[latestDaily.data.kind],
        title: latestDaily.data.title,
        href: href(`/digests/${latestDaily.id}/`),
      } : null}
      editions={olderEditions.length ? {
        title: 'Editions',
        items: olderEditions.map((d) => ({
          label: KIND_LABEL[d.data.kind],
          href: href(`/digests/${d.id}/`),
          meta: fmt(d.data.date),
        })),
        moreLabel: 'All editions',
        moreHref: href('/archive/'),
      } : null}
      feeds={{
        title: 'Subscribe',
        items: [
          { label: 'Everything', href: href('/rss.xml') },
          { label: 'Digests', href: href('/digests/rss.xml') },
          ...CATEGORIES.map((c) => ({ label: c.name, href: href(`/${c.slug}/rss.xml`) })),
        ],
        moreLabel: 'All feeds',
        moreHref: href('/feeds/'),
      }}
    />
  </div>
</Base>
