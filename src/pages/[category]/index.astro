---
import Base from '../../layouts/Base.astro';
import Pick, { type PickData } from '../../components/Pick.astro';
import picksJson from '../../data/picks.json';
import { site, href } from '../../site';
import { CATEGORIES, deriveCategory } from '../../lib/taxonomy';

export function getStaticPaths() {
  return CATEGORIES.map((c) => ({ params: { category: c.slug }, props: { category: c } }));
}
const { category } = Astro.props;

const picks = (picksJson as unknown as PickData[]).map((p) => {
  const tax = deriveCategory(p.title, p.channels);
  return { ...p, category: tax.category, subcategories: tax.subcategories } as PickData;
});
const list = picks.filter((p) => p.category === category.slug);
const lead = list[0] ?? null;
// a size ladder, not a flat list: lead → a few briefs → a compact tail
const briefRows = list.slice(1, 7);
const alsoRows = list.slice(7);

// subcategories that currently carry picks, with counts
const subCounts = category.subcategories
  .map((s) => ({ sub: s, n: list.filter((p) => (p.subcategories ?? []).includes(s.slug)).length }))
  .filter((x) => x.n > 0);
---
<Base title={`${category.name} — ${site.name}`} description={category.blurb}>
  <div class="section-head" style="padding-top:2.4rem;">
    <h1>{category.name}</h1>
    <span class="count">{list.length} {list.length === 1 ? 'pick' : 'picks'}</span>
  </div>
  <p class="cat-blurb">{category.blurb}</p>

  {subCounts.length > 0 && (
    <nav class="subchips" aria-label={`${category.name} subcategories`}>
      {subCounts.map(({ sub, n }) => (
        <a class="subchip" href={href(`/${category.slug}/${sub.slug}/`)}>{sub.name}<span class="subchip__n">{n}</span></a>
      ))}
    </nav>
  )}

  <p style="margin-top:1.1rem;">
    <a class="feed-chip" href={href(`/${category.slug}/rss.xml`)}><span class="dot"></span>Subscribe to {category.name}</a>
  </p>

  {list.length > 0 ? (
    <Fragment>
      <div class="briefing" style="margin-top:1.4rem; border-top:1px solid var(--hairline-bold);">
        {lead && <Pick pick={lead} index={0} variant="lead" />}
        {briefRows.map((p, i) => <Pick pick={p} index={i + 1} variant="brief" />)}
      </div>
      {alsoRows.length > 0 && (
        <Fragment>
          <div class="rail">
            <span class="rail__label">More in {category.name}</span>
            <span class="rail__rule"></span>
            <span class="rail__count">{alsoRows.length}</span>
          </div>
          <div class="also">
            {alsoRows.map((p, i) => <Pick pick={p} index={i} variant="also" />)}
          </div>
        </Fragment>
      )}
    </Fragment>
  ) : (
    <p class="empty-state">Nothing curated in {category.name} right now. The wire refills through the day.</p>
  )}
</Base>
