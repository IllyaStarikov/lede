---
import Base from '../layouts/Base.astro';
import { site } from '../site';
import { parseStats } from '../lib/schema';
import rawStats from '../data/stats.json';
import channelsData from '../data/channels.json';

const stats = parseStats(rawStats);
const channelName = (slug: string) =>
  channelsData.find((c) => c.slug === slug)?.name ?? slug;
const n = (x: number) => x.toLocaleString('en-US');
const byCategory = Object.entries(stats.sources.by_category)
  .filter(([, count]) => count > 0)
  .sort((a, b) => b[1] - a[1]);
const byTier = Object.entries(stats.sources.by_tier).sort((a, b) =>
  a[0].localeCompare(b[0])
);
const generated = stats.generated_at.slice(0, 19).replace('T', ' ') + ' UTC';
---
<Base title={`Stats — ${site.name}`} description="The pipeline, in numbers: sources, items, clusters, curated picks, digests.">
  <section class="stats">
    <div class="section-head" style="padding-top:2.4rem;">
      <h1>Stats</h1>
      <span class="count">generated {generated}</span>
    </div>
    <p class="measure" style="color:var(--ink-soft); font-style:italic; margin:0;">
      The pipeline, in numbers. Regenerated on every publish.
    </p>

    <div class="stat-grid">
      <div class="stat"><b>{n(stats.sources.verified)}</b><span>verified sources</span></div>
      <div class="stat"><b>{n(stats.pipeline.items_total)}</b><span>items ingested</span></div>
      <div class="stat"><b>{n(stats.pipeline.clusters_total)}</b><span>clusters</span></div>
      <div class="stat"><b>{n(stats.pipeline.curations_done)}</b><span>curated picks</span></div>
      <div class="stat"><b>{n(stats.digests.total)}</b><span>digests published</span></div>
    </div>

    <div class="cols">
      <section>
        <h3 class="label">Sources by category</h3>
        <table class="bare">
          <thead><tr><th>Category</th><th class="num">Sources</th></tr></thead>
          <tbody>
            {byCategory.map(([cat, count]) => (
              <tr><td>{cat.replaceAll('_', ' ')}</td><td class="num">{n(count)}</td></tr>
            ))}
          </tbody>
        </table>
      </section>

      <section>
        <h3 class="label">Sources by tier</h3>
        <table class="bare">
          <thead><tr><th>Tier</th><th class="num">Sources</th></tr></thead>
          <tbody>
            {byTier.map(([tier, count]) => (
              <tr><td>Tier {tier}</td><td class="num">{n(count)}</td></tr>
            ))}
          </tbody>
        </table>

        <h3 class="label" style="margin-top:2rem;">Picks by pipeline channel</h3>
        <table class="bare">
          <thead><tr><th>Pipeline channel</th><th class="num">Current picks</th></tr></thead>
          <tbody>
            {stats.channels.map((c) => (
              <tr><td>{channelName(c.slug)}</td><td class="num">{n(c.picks_current)}</td></tr>
            ))}
          </tbody>
        </table>
      </section>

      <section>
        <h3 class="label">Top surfaces, last 7 days</h3>
        <table class="bare">
          <thead><tr><th>Surface</th><th class="num">Clusters</th></tr></thead>
          <tbody>
            {stats.top_surfaces_7d.map((s) => (
              <tr><td>{s.name}</td><td class="num">{n(s.clusters)}</td></tr>
            ))}
          </tbody>
        </table>

        <h3 class="label" style="margin-top:2rem;">Models</h3>
        <table class="bare">
          <thead><tr><th>Stage</th><th>Model</th></tr></thead>
          <tbody>
            {Object.entries(stats.models).map(([stage, model]) => (
              <tr><td>{stage}</td><td><code>{model}</code></td></tr>
            ))}
          </tbody>
        </table>
      </section>
    </div>
  </section>

  <style>
    .stats h3.label { margin: 0 0 0.6rem; color: var(--accent); }
    .cols {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
      gap: 2.4rem;
      margin-top: 2.2rem;
    }
    table.bare td.num,
    table.bare th.num { text-align: right; padding-right: 0; }
    table.bare code {
      font-family: var(--mono);
      font-size: 0.8rem;
      color: var(--ink-soft);
    }
  </style>
</Base>
