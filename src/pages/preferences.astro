---
import Base from '../layouts/Base.astro';
import { site } from '../site';
import { CATEGORIES } from '../lib/taxonomy';

interface SegOption { value: string; label: string; }
// Radio groups consumed by src/scripts/prefs.js: a [data-pref-group]
// carries the key's default; the default value is stored as null (removed).
const themeOpts: SegOption[] = [
  { value: 'auto', label: 'Auto' },
  { value: 'light', label: 'Light' },
  { value: 'dark', label: 'Dark' },
];
const fontOpts: SegOption[] = [
  { value: 's', label: 'S' },
  { value: 'm', label: 'M' },
  { value: 'l', label: 'L' },
  { value: 'xl', label: 'XL' },
];
const densityOpts: SegOption[] = [
  { value: 'comfortable', label: 'Comfortable' },
  { value: 'compact', label: 'Compact' },
];
---
<Base title={`Preferences — ${site.name}`} description="Reading preferences for Lede: theme, type size, density, and how much curation detail to show. Stored on this device only.">
  <section class="prefs">
    <div class="section-head" style="padding-top:2.4rem;">
      <h1>Preferences</h1>
      <span class="count">on this device</span>
    </div>
    <p class="prefs__intro">
      Everything here lives in this browser — no account, no sync, nothing sent
      anywhere. Changes take effect as you make them, and the panel previews
      them live.
    </p>

    <noscript>
      <p class="prefs__note">
        Preferences need JavaScript. Without it the site still reads fine; you
        just get the defaults: auto theme, medium type, comfortable density.
      </p>
    </noscript>

    <div class="prefs__layout">
      <div class="prefs__controls">
        <fieldset class="pref-group">
          <legend>Appearance</legend>

          <div class="pref-field" data-pref-group data-pref-group-default="auto" role="radiogroup" aria-labelledby="lab-theme">
            <span class="pref-field__lab" id="lab-theme">Theme</span>
            <div class="seg">
              {themeOpts.map((o) => (
                <>
                  <input type="radio" name="theme" data-pref="theme" value={o.value} id={`theme-${o.value}`} />
                  <label for={`theme-${o.value}`}>{o.label}</label>
                </>
              ))}
            </div>
            <span class="pref-field__hint">Auto follows your system. The masthead toggle cycles it too.</span>
          </div>

          <div class="pref-field" data-pref-group data-pref-group-default="m" role="radiogroup" aria-labelledby="lab-fontsize">
            <span class="pref-field__lab" id="lab-fontsize">Type size</span>
            <div class="seg">
              {fontOpts.map((o) => (
                <>
                  <input type="radio" name="fontSize" data-pref="fontSize" value={o.value} id={`fontsize-${o.value}`} />
                  <label for={`fontsize-${o.value}`}>{o.label}</label>
                </>
              ))}
            </div>
            <span class="pref-field__hint">Scales the whole page, small to extra-large.</span>
          </div>

          <div class="pref-field" data-pref-group data-pref-group-default="comfortable" role="radiogroup" aria-labelledby="lab-density">
            <span class="pref-field__lab" id="lab-density">Density</span>
            <div class="seg">
              {densityOpts.map((o) => (
                <>
                  <input type="radio" name="density" data-pref="density" value={o.value} id={`density-${o.value}`} />
                  <label for={`density-${o.value}`}>{o.label}</label>
                </>
              ))}
            </div>
            <span class="pref-field__hint">Compact tightens the rows and folds away per-pick notes.</span>
          </div>
        </fieldset>

        <fieldset class="pref-group">
          <legend>Detail</legend>
          <label class="pref-toggle">
            <input type="checkbox" data-pref="showSignals" id="pref-signals" />
            <span class="pref-toggle__box" aria-hidden="true"></span>
            <span class="pref-toggle__text">
              <span class="pref-toggle__name">Show curation signals</span>
              <span class="pref-field__hint">Per pick: where it surfaced and how loudly, relevance, score, and which model curated it.</span>
            </span>
          </label>
          <label class="pref-toggle">
            <input type="checkbox" data-pref="showScores" id="pref-scores" />
            <span class="pref-toggle__box" aria-hidden="true"></span>
            <span class="pref-toggle__text">
              <span class="pref-toggle__name">Show scores inline</span>
              <span class="pref-field__hint">Relevance and score in each pick's byline.</span>
            </span>
          </label>
        </fieldset>

        <fieldset class="pref-group">
          <legend>Sections</legend>
          <p class="pref-field__hint" style="margin-bottom:var(--space-4);">
            Switch off sections you don't want on the front page or in the nav.
            A muted section still keeps its own page and feed — it's just out of
            your way here.
          </p>
          <div class="mute-grid">
            {CATEGORIES.map((c) => (
              <label class="pref-toggle pref-toggle--compact">
                <input type="checkbox" data-mute={c.slug} id={`mute-${c.slug}`} checked />
                <span class="pref-toggle__box" aria-hidden="true"></span>
                <span class="pref-toggle__name">{c.name}</span>
              </label>
            ))}
          </div>
          <div class="mute-actions">
            <button type="button" class="danger" data-mute-none>Show all</button>
            <button type="button" class="danger" data-mute-all>Mute all</button>
          </div>
        </fieldset>

        <div class="pref-reset">
          <button type="button" class="danger" data-prefs-reset>Reset to defaults</button>
          <span class="pref-field__hint">Clears every Lede preference stored in this browser.</span>
        </div>
      </div>

      <aside class="prefs__preview" aria-label="Live preview of your settings">
        <span class="prefs__preview-lab">Preview</span>
        <div class="briefing">
          <article class="pick pick--brief">
            <div class="pick__meta">
              <span class="pick__no" aria-hidden="true">01</span>
              <span class="pick__src">example.com</span>
              <span class="pick__date">2026-06-13</span>
              <a class="pick__tag" href="#" aria-hidden="true" tabindex="-1">ai</a>
              <span class="pick__score">9/10<span class="sep" aria-hidden="true"></span>score 5.7</span>
            </div>
            <h3 class="pick__title"><a href="#" aria-hidden="true" tabindex="-1">A sample headline, set the way your picks will read</a></h3>
            <p class="pick__why">The one-line account of why it matters sits here. Your settings change how much shows around it.</p>
            <details class="pick__details">
              <summary>Details</summary>
              <ul class="pick__notes">
                <li>A load-bearing specific from the story.</li>
                <li>Another concrete detail worth keeping.</li>
              </ul>
            </details>
            <aside class="pick__signals" aria-label="Curation signals">
              <span class="lab">Signals</span>
              <span>3 sources</span>
              <span>relevance 9/10</span>
              <span>score 5.72</span>
              <span>curator: claude-sonnet-4-6</span>
            </aside>
          </article>
        </div>
        <span class="prefs__preview-foot">Toggle the controls and watch this update.</span>
      </aside>
    </div>
  </section>
</Base>
