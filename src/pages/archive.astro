---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { site, href, KINDS, KIND_LABEL } from '../site';

const digests = (await getCollection('digests')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
// Group by kind in KINDS order; skip kinds with nothing published yet.
const groups = KINDS.map((kind) => ({
  kind,
  entries: digests.filter((d) => d.data.kind === kind),
})).filter((g) => g.entries.length > 0);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
---
<Base title={`Archive — ${site.name}`} description="Every edition Lede has published, daily brief to the year in review.">
  <div class="section-head" style="padding-top:2.4rem;">
    <h2>The archive</h2>
    <span class="count">{digests.length} {digests.length === 1 ? 'edition' : 'editions'}</span>
  </div>

  {groups.map((g) => (
    <section>
      <div class="section-head">
        <h2 style="font-size:1.25rem;">{KIND_LABEL[g.kind]}</h2>
        <span class="count">
          {g.entries.length} {g.entries.length === 1 ? 'edition' : 'editions'}
        </span>
      </div>
      <div class="picks">
        {g.entries.map((d, i) => (
          <article class="pick reveal arch" style={`animation-delay:${Math.min(i, 8) * 50}ms`}>
            <div class="label arch__period">{d.data.period}</div>
            <div>
              <h3 class="pick__title" style="margin-bottom:0.4rem;">
                <a href={href(`/digests/${d.id}/`)}>{d.data.title}</a>
              </h3>
              <p class="pick__why" style="font-style:italic; color:var(--ink-soft); margin-bottom:0.3rem;">{d.data.blurb}</p>
              <span class="label">{fmt(d.data.date)}</span>
            </div>
          </article>
        ))}
      </div>
      <p style="margin:1rem 0 0;">
        <a class="feed-chip" href={href(`/digests/${g.kind}/rss.xml`)}>
          <span class="dot"></span>{KIND_LABEL[g.kind]} feed
        </a>
      </p>
    </section>
  ))}

  <style>
    .arch {
      display: grid;
      grid-template-columns: 7rem 1fr;
      gap: 0 1rem;
    }
    .arch__period { padding-top: 0.5rem; }
    @media (max-width: 38rem) {
      .arch { grid-template-columns: 1fr; }
      .arch__period { padding-top: 0; }
    }
  </style>
</Base>
