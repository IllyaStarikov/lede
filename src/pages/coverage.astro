---
import Base from '../layouts/Base.astro';
import { site, href } from '../site';
import { parseStats } from '../lib/schema';
import rawStats from '../data/stats.json';

const stats = parseStats(rawStats);
const n = (x: number) => x.toLocaleString('en-US');
const generated = stats.generated_at.slice(0, 19).replace('T', ' ') + ' UTC';

const SRC_CAT_LABEL: Record<string, string> = {
  aggregators: 'Aggregators',
  ai_companies: 'AI companies',
  devtools: 'Dev tools',
  expert_blogs: 'Expert blogs',
  hardware_science: 'Hardware & science',
  news: 'News',
  newsletters: 'Newsletters',
  physics: 'Physics',
  research: 'Research',
  science: 'Science',
  tech_news: 'Tech news',
  security: 'Security',
};
const label = (k: string) => SRC_CAT_LABEL[k] ?? k.replaceAll('_', ' ');
const pct = (v: number, max: number) => Math.max(2, Math.round((v / max) * 100));

const byCat = Object.entries(stats.sources.by_category)
  .filter(([, c]) => c > 0)
  .sort((a, b) => b[1] - a[1]);
const maxCat = Math.max(...byCat.map(([, c]) => c), 1);

const TIER_NOTE: Record<string, string> = { '1': 'flagship', '2': 'core', '3': 'niche' };
const byTier = Object.entries(stats.sources.by_tier).sort((a, b) => a[0].localeCompare(b[0]));
const maxTier = Math.max(...byTier.map(([, c]) => c), 1);

const surfaces = stats.top_surfaces_7d.slice(0, 14);
const maxSurface = Math.max(...surfaces.map((s) => s.clusters), 1);
---
<Base title={`Coverage — ${site.name}`} description="What Lede reads and indexes: sources by category and tier, the loudest surfaces, and the volume behind every edition. Generated by the pipeline, not by hand.">
  <div class="section-head" style="padding-top:2.4rem;">
    <h1>Coverage</h1>
    <span class="count">as of {generated}</span>
  </div>
  <p class="cat-blurb">
    What the wire reads, and what it does with it. Every figure is generated by
    the pipeline on each publish — nothing is hand-entered. The full roll is on
    the <a href={href('/sources/')}>sources</a> page.
  </p>

  <div class="stat-grid">
    <div class="stat"><b>{n(stats.sources.verified)}</b><span>verified sources</span></div>
    <div class="stat"><b>{n(stats.pipeline.items_total)}</b><span>items ingested</span></div>
    <div class="stat"><b>{n(stats.pipeline.clusters_total)}</b><span>stories clustered</span></div>
    <div class="stat"><b>{n(stats.pipeline.curations_done)}</b><span>curated picks</span></div>
    {stats.pipeline.avg_relevance_7d != null && (
      <div class="stat"><b>{stats.pipeline.avg_relevance_7d.toFixed(1)}</b><span>avg relevance, 7d</span></div>
    )}
  </div>

  <div class="rail">
    <span class="rail__label">Sources by category</span>
    <span class="rail__rule"></span>
    <span class="rail__count">{n(stats.sources.verified)} total</span>
  </div>
  <ul class="bars">
    {byCat.map(([cat, c]) => (
      <li class={c === maxCat ? 'bar bar--lead' : 'bar'}>
        <span class="bar__label">{label(cat)}</span>
        <span class="bar__track"><span class="bar__fill" style={`width:${pct(c, maxCat)}%`}></span></span>
        <span class="bar__val">{n(c)}</span>
      </li>
    ))}
  </ul>

  <div class="rail">
    <span class="rail__label">Sources by tier</span>
    <span class="rail__rule"></span>
    <span class="rail__count">flagship to niche</span>
  </div>
  <ul class="bars">
    {byTier.map(([tier, c]) => (
      <li class={c === maxTier ? 'bar bar--lead' : 'bar'}>
        <span class="bar__label">Tier {tier} {TIER_NOTE[tier] ?? ''}</span>
        <span class="bar__track"><span class="bar__fill" style={`width:${pct(c, maxTier)}%`}></span></span>
        <span class="bar__val">{n(c)}</span>
      </li>
    ))}
  </ul>

  <div class="rail">
    <span class="rail__label">Loudest surfaces, 7 days</span>
    <span class="rail__rule"></span>
    <span class="rail__count">by clusters</span>
  </div>
  <ul class="bars">
    {surfaces.map((s) => (
      <li class={s.clusters === maxSurface ? 'bar bar--lead' : 'bar'}>
        <span class="bar__label" title={s.name}>{s.name}</span>
        <span class="bar__track"><span class="bar__fill" style={`width:${pct(s.clusters, maxSurface)}%`}></span></span>
        <span class="bar__val">{n(s.clusters)}</span>
      </li>
    ))}
  </ul>

  <p class="coverage-foot">
    A “surface” is a place a story shows up — Hacker News, an arXiv section, a
    subreddit. One story usually surfaces in several; the pipeline clusters them
    into one pick, so the same news isn't counted twice. For the raw tables —
    picks per section, the models behind each stage — see
    <a href={href('/stats/')}>the numbers</a>.
  </p>
</Base>
